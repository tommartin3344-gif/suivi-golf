import React, { useState, useEffect, useMemo } from 'react';
import { Plus, Trash2, Pencil, X, Check, Package } from 'lucide-react';
import { supabase } from './supabaseClient';

const CATEGORIES = [
  { value: 'clubs', label: 'Clubs' },
  { value: 'balles', label: 'Balles' },
  { value: 'tees', label: 'Tees' },
  { value: 'gants', label: 'Gants' },
  { value: 'grips', label: 'Grips' },
  { value: 'vetements', label: 'Vêtements' },
  { value: 'accessoires', label: 'Accessoires' },
  { value: 'autre', label: 'Autre' },
];

const emptyItem = {
  id: null,
  nom: '',
  categorie: 'balles',
  quantite: 1,
  prixUnitaire: '',
  dateAchat: '',
  notes: '',
};

function itemFromDb(row) {
  return {
    id: row.id,
    nom: row.nom,
    categorie: row.categorie || 'autre',
    quantite: row.quantite ?? 1,
    prixUnitaire: row.prix_unitaire ?? '',
    dateAchat: row.date_achat || '',
    notes: row.notes || '',
  };
}

function itemToDb(i) {
  return {
    nom: i.nom,
    categorie: i.categorie,
    quantite: Number(i.quantite) || 0,
    prix_unitaire: Number(i.prixUnitaire) || 0,
    date_achat: i.dateAchat || null,
    notes: i.notes || null,
  };
}

function formatEuros(n) {
  const v = Number(n) || 0;
  return v.toLocaleString('fr-FR', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + ' €';
}

export default function Inventaire() {
  const [items, setItems] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState(emptyItem);
  const [filtreCategorie, setFiltreCategorie] = useState('toutes');
  const [error, setError] = useState('');

  useEffect(() => {
    async function charger() {
      const { data, error: err } = await supabase
        .from('inventaire')
        .select('*')
        .order('created_at', { ascending: true });
      if (!err && data) setItems(data.map(itemFromDb));
      setLoading(false);
    }
    charger();
  }, []);

  function openNewForm() {
    setForm(emptyItem);
    setShowForm(true);
  }

  function openEditForm(item) {
    setForm(item);
    setShowForm(true);
  }

  async function handleSave(e) {
    e.preventDefault();
    if (!form.nom) {
      setError('Le nom est requis.');
      return;
    }
    setError('');

    if (form.id) {
      const { data, error: updErr } = await supabase
        .from('inventaire')
        .update(itemToDb(form))
        .eq('id', form.id)
        .select()
        .single();
      if (updErr) {
        setError("Erreur d'enregistrement. Réessaie.");
        return;
      }
      setItems(items.map((i) => (i.id === form.id ? itemFromDb(data) : i)));
    } else {
      const { data, error: insErr } = await supabase.from('inventaire').insert(itemToDb(form)).select().single();
      if (insErr) {
        setError("Erreur d'enregistrement. Réessaie.");
        return;
      }
      setItems([...items, itemFromDb(data)]);
    }
    setShowForm(false);
    setForm(emptyItem);
  }

  async function handleDelete(id) {
    const previous = items;
    setItems(items.filter((i) => i.id !== id));
    const { error: delErr } = await supabase.from('inventaire').delete().eq('id', id);
    if (delErr) {
      setError('Erreur de suppression. Réessaie.');
      setItems(previous);
    }
  }

  const { itemsFiltres, valeurTotale, parCategorie } = useMemo(() => {
    const itemsFiltres =
      filtreCategorie === 'toutes' ? items : items.filter((i) => i.categorie === filtreCategorie);
    const valeurTotale = items.reduce((sum, i) => sum + (Number(i.prixUnitaire) || 0) * (Number(i.quantite) || 0), 0);
    const parCategorie = CATEGORIES.map((c) => ({
      ...c,
      valeur: items
        .filter((i) => i.categorie === c.value)
        .reduce((sum, i) => sum + (Number(i.prixUnitaire) || 0) * (Number(i.quantite) || 0), 0),
      count: items.filter((i) => i.categorie === c.value).length,
    })).filter((c) => c.count > 0);
    return { itemsFiltres, valeurTotale, parCategorie };
  }, [items, filtreCategorie]);

  if (loading) {
    return <p className="text-stone-400 text-sm text-center py-16">Chargement...</p>;
  }

  return (
    <div>
      <div className="flex items-center justify-between mb-4 flex-wrap gap-2">
        <div>
          <h2 className="text-[#0d2340] font-bold text-lg">Mon sac & matériel</h2>
          <p className="text-stone-400 text-xs mt-0.5">
            {items.length} article{items.length > 1 ? 's' : ''} · valeur totale{' '}
            <span className="font-semibold text-[#0d2340]">{formatEuros(valeurTotale)}</span>
          </p>
        </div>
        <button
          onClick={openNewForm}
          className="flex items-center gap-1.5 bg-[#0d2340] text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-[#0d2340]/90 transition"
        >
          <Plus size={16} /> Ajouter un article
        </button>
      </div>

      {error && (
        <div className="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-2 rounded-lg">{error}</div>
      )}

      {parCategorie.length > 0 && (
        <div className="flex flex-wrap gap-1.5 mb-4">
          <button
            onClick={() => setFiltreCategorie('toutes')}
            className={`text-xs font-medium px-3 py-1.5 rounded-full border transition ${
              filtreCategorie === 'toutes'
                ? 'bg-[#0d2340] text-white border-[#0d2340]'
                : 'bg-white text-stone-500 border-stone-300'
            }`}
          >
            Toutes ({items.length})
          </button>
          {parCategorie.map((c) => (
            <button
              key={c.value}
              onClick={() => setFiltreCategorie(c.value)}
              className={`text-xs font-medium px-3 py-1.5 rounded-full border transition ${
                filtreCategorie === c.value
                  ? 'bg-[#0d2340] text-white border-[#0d2340]'
                  : 'bg-white text-stone-500 border-stone-300'
              }`}
            >
              {c.label} ({c.count})
            </button>
          ))}
        </div>
      )}

      {items.length === 0 && !showForm && (
        <div className="text-center py-16 border border-dashed border-stone-300 rounded-xl">
          <Package className="mx-auto mb-3 text-stone-300" size={32} />
          <p className="text-stone-500 text-sm">Ton sac est vide pour l'instant.</p>
          <button onClick={openNewForm} className="mt-3 text-[#0d2340] text-sm font-medium underline">
            Ajouter ton premier article
          </button>
        </div>
      )}

      <div className="space-y-2">
        {itemsFiltres.map((item) => (
          <div
            key={item.id}
            className="bg-white border border-stone-200 rounded-xl p-3.5 flex items-center justify-between gap-4 hover:border-stone-300 transition"
          >
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2 flex-wrap">
                <h3 className="font-semibold text-[#0d2340] text-sm">{item.nom}</h3>
                <span className="text-[11px] font-medium px-2 py-0.5 rounded-full border bg-stone-100 text-stone-600 border-stone-300">
                  {CATEGORIES.find((c) => c.value === item.categorie)?.label}
                </span>
              </div>
              <div className="flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-stone-500 mt-1">
                <span>Qté : {item.quantite}</span>
                {Number(item.prixUnitaire) > 0 && (
                  <span>
                    {formatEuros(item.prixUnitaire)} / unité · total{' '}
                    <span className="font-semibold text-[#0d2340]">
                      {formatEuros(Number(item.prixUnitaire) * Number(item.quantite))}
                    </span>
                  </span>
                )}
                {item.dateAchat && (
                  <span>Acheté le {new Date(item.dateAchat + 'T00:00:00').toLocaleDateString('fr-FR')}</span>
                )}
              </div>
              {item.notes && <p className="text-xs text-stone-400 mt-1">{item.notes}</p>}
            </div>
            <div className="flex gap-1 shrink-0">
              <button
                onClick={() => openEditForm(item)}
                className="p-1.5 text-stone-400 hover:text-[#0d2340] hover:bg-stone-50 rounded-lg"
              >
                <Pencil size={14} />
              </button>
              <button
                onClick={() => handleDelete(item.id)}
                className="p-1.5 text-stone-400 hover:text-red-600 hover:bg-red-50 rounded-lg"
              >
                <Trash2 size={14} />
              </button>
            </div>
          </div>
        ))}
      </div>

      {showForm && (
        <div
          className="fixed inset-0 bg-black/40 flex items-center justify-center p-4 z-[9999]"
          onClick={() => setShowForm(false)}
        >
          <form
            onClick={(e) => e.stopPropagation()}
            onSubmit={handleSave}
            className="bg-white rounded-xl w-full max-w-md p-6 max-h-[90vh] overflow-y-auto"
          >
            <div className="flex items-center justify-between mb-4">
              <h3 className="font-bold text-[#0d2340] text-lg">{form.id ? "Modifier l'article" : 'Nouvel article'}</h3>
              <button type="button" onClick={() => setShowForm(false)} className="text-stone-400 hover:text-stone-600">
                <X size={18} />
              </button>
            </div>

            <div className="space-y-3">
              <div>
                <label className="text-xs font-medium text-stone-500 mb-1 block">Nom *</label>
                <input
                  className="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-[#0d2340]"
                  value={form.nom}
                  onChange={(e) => setForm({ ...form, nom: e.target.value })}
                  placeholder="Balles Titleist Pro V1"
                />
              </div>

              <div>
                <label className="text-xs font-medium text-stone-500 mb-1 block">Catégorie</label>
                <div className="flex flex-wrap gap-1.5">
                  {CATEGORIES.map((c) => (
                    <button
                      type="button"
                      key={c.value}
                      onClick={() => setForm({ ...form, categorie: c.value })}
                      className={`text-xs font-medium px-2.5 py-1.5 rounded-lg border transition ${
                        form.categorie === c.value
                          ? 'bg-[#0d2340] text-white border-[#0d2340]'
                          : 'bg-white text-stone-400 border-stone-200'
                      }`}
                    >
                      {c.label}
                    </button>
                  ))}
                </div>
              </div>

              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-xs font-medium text-stone-500 mb-1 block">Quantité</label>
                  <input
                    type="number"
                    min="0"
                    step="1"
                    className="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-[#0d2340]"
                    value={form.quantite}
                    onChange={(e) => setForm({ ...form, quantite: e.target.value })}
                  />
                </div>
                <div>
                  <label className="text-xs font-medium text-stone-500 mb-1 block">Prix unitaire (€)</label>
                  <input
                    type="number"
                    min="0"
                    step="0.01"
                    className="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-[#0d2340]"
                    value={form.prixUnitaire}
                    onChange={(e) => setForm({ ...form, prixUnitaire: e.target.value })}
                    placeholder="0"
                  />
                </div>
              </div>

              <div>
                <label className="text-xs font-medium text-stone-500 mb-1 block">Date d'achat</label>
                <input
                  type="date"
                  className="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-[#0d2340]"
                  value={form.dateAchat}
                  onChange={(e) => setForm({ ...form, dateAchat: e.target.value })}
                />
              </div>

              <div>
                <label className="text-xs font-medium text-stone-500 mb-1 block">Notes</label>
                <textarea
                  className="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-[#0d2340] resize-none"
                  rows={2}
                  value={form.notes}
                  onChange={(e) => setForm({ ...form, notes: e.target.value })}
                  placeholder="Marque, référence, état..."
                />
              </div>

              {Number(form.prixUnitaire) > 0 && (
                <p className="text-xs text-stone-400 text-right">
                  Total :{' '}
                  <span className="font-semibold text-[#0d2340]">
                    {formatEuros(Number(form.prixUnitaire) * (Number(form.quantite) || 0))}
                  </span>
                </p>
              )}
            </div>

            <div className="flex gap-2 mt-5">
              <button
                type="button"
                onClick={() => setShowForm(false)}
                className="flex-1 border border-stone-300 text-stone-600 text-sm font-medium py-2 rounded-lg hover:bg-stone-50"
              >
                Annuler
              </button>
              <button
                type="submit"
                className="flex-1 bg-[#0d2340] text-white text-sm font-medium py-2 rounded-lg hover:bg-[#0d2340]/90 flex items-center justify-center gap-1.5"
              >
                <Check size={16} /> Enregistrer
              </button>
            </div>
          </form>
        </div>
      )}
    </div>
  );
}
