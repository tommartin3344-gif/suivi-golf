import React, { useState, useEffect } from 'react';
import { supabase } from './supabaseClient';
import Auth from './Auth';
import Paywall from './Paywall';
import SuiviTournois from './App';

export default function AppRoot() {
  const [session, setSession] = useState(undefined); // undefined = chargement, null = pas connecté
  const [abonnement, setAbonnement] = useState(undefined); // undefined = chargement

  useEffect(() => {
    supabase.auth.getSession().then(({ data }) => setSession(data.session));

    const { data: listener } = supabase.auth.onAuthStateChange((_event, newSession) => {
      setSession(newSession);
    });

    return () => listener.subscription.unsubscribe();
  }, []);

  useEffect(() => {
    if (!session) {
      setAbonnement(undefined);
      return;
    }
    async function verifierAbonnement() {
      const { data } = await supabase.from('abonnements').select('statut').maybeSingle();
      setAbonnement(data?.statut || 'inactif');
    }
    verifierAbonnement();

    function onVisible() {
      if (document.visibilityState === 'visible') verifierAbonnement();
    }
    document.addEventListener('visibilitychange', onVisible);
    return () => document.removeEventListener('visibilitychange', onVisible);
  }, [session]);

  if (session === undefined) {
    return (
      <div className="min-h-screen bg-[#0d2340] flex items-center justify-center">
        <p className="text-white/60 text-sm">Chargement...</p>
      </div>
    );
  }

  if (!session) {
    return <Auth />;
  }

  if (abonnement === undefined) {
    return (
      <div className="min-h-screen bg-[#0d2340] flex items-center justify-center">
        <p className="text-white/60 text-sm">Chargement...</p>
      </div>
    );
  }

  if (abonnement !== 'essai' && abonnement !== 'actif') {
    return <Paywall statut={abonnement} />;
  }

  return <SuiviTournois key={session.user.id} />;
}
